{
  "name": "@articulink/design-system",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "style": "./src/tokens/index.css",
      "default": "./src/tokens/index.css"
    },
    "./src/tokens/index.css": {
